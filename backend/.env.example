# Copy this file to .env and fill in real values

# Which port THIS server runs on. On 2 EC2s you can keep 4000 on both.
PORT=4000

# MongoDB connection (single EC2 with Mongo, or Atlas URL)
MONGO_URI=mongodb://localhost:27017/chatapp

# Valkey / Redis connection (single EC2 with Valkey, or ElastiCache endpoint)
VALKEY_URL=redis://localhost:6379

# Secret used to sign JWT login tokens (use a long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret

# Where the frontend runs (for CORS). Use * while developing.
CLIENT_ORIGIN=*
